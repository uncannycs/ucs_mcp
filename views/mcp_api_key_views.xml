<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_mcp_api_key_list" model="ir.ui.view">
        <field name="name">mcp.api.key.list</field>
        <field name="model">mcp.api.key</field>
        <field name="arch" type="xml">
            <list string="MCP API Keys" decoration-muted="not active">
                <field name="name"/>
                <field name="key_prefix"/>
                <field name="user_id"/>
                <field name="expiry_date"/>
                <field name="rate_limit"/>
                <field name="perm_read"/>
                <field name="perm_write"/>
                <field name="perm_create"/>
                <field name="perm_delete"/>
                <field name="perm_execute"/>
                <field name="last_used"/>
                <field name="use_count"/>
                <field name="active" invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_mcp_api_key_form" model="ir.ui.view">
        <field name="name">mcp.api.key.form</field>
        <field name="model">mcp.api.key</field>
        <field name="arch" type="xml">
            <form string="MCP API Key">
                <header>
                    <button name="action_regenerate_key" string="Regenerate Key"
                            type="object" class="btn-secondary"
                            confirm="Regenerating deactivates this key and creates a new one. Continue?"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger"
                            invisible="active"/>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Key name"/></h1>
                    </div>
                    <group>
                        <group string="Identity">
                            <field name="user_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="key_prefix" readonly="1"/>
                            <field name="expiry_date"/>
                            <field name="active"/>
                        </group>
                        <group string="Rate Limiting">
                            <field name="rate_limit"/>
                            <field name="request_count" readonly="1"/>
                            <field name="rate_window_start" readonly="1"/>
                            <field name="last_used" readonly="1"/>
                            <field name="use_count" readonly="1"/>
                        </group>
                    </group>
                    <group string="Permissions">
                        <group>
                            <field name="perm_read"/>
                            <field name="perm_write"/>
                            <field name="perm_create"/>
                        </group>
                        <group>
                            <field name="perm_delete"/>
                            <field name="perm_execute"/>
                        </group>
                    </group>
                    <group string="Model Access Control">
                        <field name="allowed_models" placeholder="sale.order, account.move (empty = all allowed)"/>
                        <field name="custom_blocked_models" placeholder="hr.payslip, res.users"/>
                    </group>
                    <notebook>
                        <page string="Setup Guide" name="setup_guide">
                            <field name="setup_guide_html" readonly="1" nolabel="1" colspan="2"
                                   widget="html"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_mcp_api_key" model="ir.actions.act_window">
        <field name="name">MCP API Keys</field>
        <field name="res_model">mcp.api.key</field>
        <field name="view_mode">list,form</field>
        <field name="context">{"active_test": False}</field>
    </record>

    <record id="action_mcp_portal_link" model="ir.actions.act_url">
        <field name="name">User Portal</field>
        <field name="url">/mcp/connect</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_mcp_root" name="MCP" sequence="90"
              groups="ucs_mcp.group_mcp_user,ucs_mcp.group_mcp_admin"/>
    <menuitem id="menu_mcp_api_keys" name="API Keys" parent="menu_mcp_root"
              action="action_mcp_api_key" sequence="10"/>
    <menuitem id="menu_mcp_generate_key" name="Generate New Key" parent="menu_mcp_root"
              action="action_mcp_api_key_wizard" sequence="20"/>
    <menuitem id="menu_mcp_portal" name="Open User Portal ↗" parent="menu_mcp_root"
              action="action_mcp_portal_link" sequence="30"
              groups="ucs_mcp.group_mcp_admin"/>

</odoo>
