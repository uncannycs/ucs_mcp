<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Module category — makes MCP groups visible in Settings → Users form -->
    <record id="module_category_mcp" model="ir.module.category">
        <field name="name">MCP Server</field>
        <field name="description">Manage MCP API keys and audit logs.</field>
        <field name="sequence">100</field>
    </record>

    <data noupdate="1">

    <record id="group_mcp_admin" model="res.groups">
        <field name="name">MCP Administrator</field>
        <field name="category_id" ref="module_category_mcp"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        <field name="comment">Full access to MCP API keys and audit logs. Can manage all keys.</field>
    </record>

    <record id="group_mcp_user" model="res.groups">
        <field name="name">MCP User</field>
        <field name="category_id" ref="module_category_mcp"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        <field name="comment">Can create and manage own MCP API keys. Read-only access to audit log.</field>
    </record>

    <!-- Users can only see their own API keys -->
    <record id="rule_mcp_api_key_own" model="ir.rule">
        <field name="name">MCP API Key: own keys only</field>
        <field name="model_id" ref="model_mcp_api_key"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('ucs_mcp.group_mcp_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Admins bypass the record rule — see all keys -->
    <record id="rule_mcp_api_key_admin" model="ir.rule">
        <field name="name">MCP API Key: admin sees all</field>
        <field name="model_id" ref="model_mcp_api_key"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('ucs_mcp.group_mcp_admin'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    </data>
</odoo>
