<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <record id="param_mcp_audit_log_retention_days" model="ir.config_parameter">
        <field name="key">ucs_mcp.audit_log_retention_days</field>
        <field name="value">90</field>
    </record>

    <record id="ir_cron_mcp_audit_log_purge" model="ir.cron">
        <field name="name">MCP: Purge Old Audit Logs</field>
        <field name="model_id" ref="model_mcp_audit_log"/>
        <field name="state">code</field>
        <field name="code">model._cron_purge_old_logs()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active">True</field>
    </record>

</odoo>
